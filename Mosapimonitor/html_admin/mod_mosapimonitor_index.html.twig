{% extends request.ajax ? "layout_blank.html.twig" : "layout_default.html.twig" %}

{% block meta_title %}{{ 'ICANN MoSAPI Monitor'|trans }}{% endblock %}

{% set active_menu = 'mosapimonitor' %}

{% block content %}
<div class="card">
  <div class="card-header">
    <h3 class="card-title">ICANN MoSAPI Monitor</h3>
    <div class="card-actions">
      <a class="btn btn-primary" href="{{ 'mosapimonitor?refresh=1'|alink }}">
        <i class="fas fa-sync"></i> Refresh now
      </a>
    </div>
  </div>

  <div class="card-body">

    {% if error %}
      <div class="alert alert-danger">
        <strong>Error:</strong> {{ error }}
      </div>
    {% endif %}

    {% if not configured %}
      <div class="alert alert-warning">
        <strong>ICANN MoSAPI Monitor is not configured.</strong>
        Add your IANA ID and registrar credentials in module settings to activate monitoring.
        <div class="mt-2">
          <a href="{{ 'extension/settings/mosapimonitor'|alink }}" class="btn btn-sm btn-primary">
            Configure Now
          </a>
        </div>
      </div>
    {% endif %}

    {% if data %}
      <div class="alert alert-info">
        <strong>Cache:</strong> {{ data.meta.cache|default('unknown') }}
        {% if data.meta.fetched_at %} | <strong>Fetched:</strong> {{ data.meta.fetched_at }}{% endif %}
      </div>

      <h4>Registrar State</h4>
      {% set state = data.state %}
      <table class="table table-striped">
        <tr><th style="width:220px;">Registrar</th><td>{{ (state.tld ?? state.registrarID ?? 'N/A')|e }}</td></tr>
        <tr><th>Status</th><td>{{ (state.status ?? 'Unknown')|e }}</td></tr>
        <tr><th>Updated</th>
          <td>
            {% if state.lastUpdateApiDatabase is defined %}
              {{ state.lastUpdateApiDatabase|date('Y-m-d H:i:s') }}
            {% else %}
              N/A
            {% endif %}
          </td>
        </tr>
      </table>

      <h5>Tested Services</h5>
      <table class="table table-bordered">
        <thead>
          <tr>
            <th>Service</th>
            <th>Status</th>
            <th>Emergency Threshold</th>
            <th>Incidents</th>
          </tr>
        </thead>
        <tbody>
          {% for name, svc in state.testedServices %}
            <tr>
              <td>{{ name|e }}</td>
              <td>{{ (svc.status ?? 'Unknown')|e }}</td>
              <td>
                {% if svc.emergencyThreshold is defined and svc.emergencyThreshold is not null %}
                  {{ svc.emergencyThreshold }}%
                {% else %}
                  0%
                {% endif %}
              </td>
              <td>
                {% if svc.incidents is defined and svc.incidents %}
                  {% for inc in svc.incidents %}
                    <div style="margin-bottom:8px;">
                      <strong>{{ inc.incidentID|default('N/A')|e }}</strong>:
                      {{ inc.state|default('Unknown')|e }}<br>
                      <small class="text-muted">
                        since {{ inc.startTime|date('Y-m-d H:i:s') }}
                        (end:
                        {% if inc.endTime %}
                          {{ inc.endTime|date('Y-m-d H:i:s') }}
                        {% else %}
                          Active
                        {% endif %}
                        )
                      </small>
                    </div>
                  {% endfor %}
                {% else %}
                  <span class="text-muted">None</span>
                {% endif %}
              </td>
            </tr>
          {% else %}
            <tr><td colspan="4" class="text-muted">No testedServices data found.</td></tr>
          {% endfor %}
        </tbody>
      </table>

      <hr>

      <h4>Domain METRICA (latest)</h4>
      {% set m = data.metrica %}
      <table class="table table-striped">
        <tr><th style="width:220px;">Report Date</th><td>{{ (m.domainListDate ?? 'N/A')|e }}</td></tr>
        <tr><th>IANA ID</th><td>{{ (m.ianaId ?? 'N/A')|e }}</td></tr>
        <tr><th>Unique Abuses</th><td>{{ (m.uniqueAbuseDomains ?? 'N/A')|e }}</td></tr>
      </table>

      <h5>Threat Types</h5>
      <table class="table table-bordered">
        <thead><tr><th>Threat</th><th>Count</th><th>Domains</th></tr></thead>
        <tbody>
          {% for entry in m.domainListData %}
            <tr>
              <td>{{ (entry.threatType ?? 'Unknown')|e }}</td>
              <td>
                {% if entry.count is defined and entry.count >= 0 %}
                  {{ entry.count }}
                {% else %}
                  N/A
                {% endif %}
              </td>
              <td>
                {% if cfg.show_domains %}
                  {% if entry.domains is defined and entry.domains %}
                    <div style="max-height:220px; overflow:auto; border:1px solid #ddd; padding:8px; border-radius:4px;">
                      {% for d in entry.domains %}
                        {{ d|e }}<br>
                      {% endfor %}
                    </div>
                  {% else %}
                    <span class="text-muted">None</span>
                  {% endif %}
                {% else %}
                  <span class="text-muted">Hidden</span>
                {% endif %}
              </td>
            </tr>
          {% else %}
            <tr><td colspan="3" class="text-muted">No domainListData found.</td></tr>
          {% endfor %}
        </tbody>
      </table>

    {% endif %}
  </div>
</div>
{% endblock %}